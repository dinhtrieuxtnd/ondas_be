# ══════════════════════════════════════════════════════════
#  .env.example — Template cho file .env production
#
#  Cách dùng:
#    1. Copy file này: cp .env.example .env.prod
#    2. Điền giá trị thật vào .env.prod
#    3. Upload .env.prod lên Jenkins (Credentials → Secret file → ID: prod-env-file)
#    4. KHÔNG commit .env.prod lên Git (đã có trong .gitignore)
#
#  Tạo JWT_SECRET: openssl rand -hex 32
# ══════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=ondas_db
POSTGRES_USER=ondas_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_EXPIRATION=86400000

# ── (Tương lai) Redis ────────────────────────────────────
# REDIS_PASSWORD=

# ── (Tương lai) Email / SMTP ─────────────────────────────
# MAIL_USERNAME=
# MAIL_PASSWORD=

# ── (Tương lai) S3 / Object Storage ─────────────────────
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
