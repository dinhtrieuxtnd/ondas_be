# ══════════════════════════════════════════════════════════
#  .env.example — Template cho file .env production
#
#  Cách dùng:
#    1. Copy file này: cp .env.example .env.prod
#    2. Điền giá trị thật vào .env.prod
#    3. Upload .env.prod lên Jenkins (Credentials → Secret file → ID: prod-env-file)
#    4. KHÔNG commit .env.prod lên Git (đã có trong .gitignore)
#
#  Tạo JWT_SECRET: openssl rand -hex 32
# ══════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DB=ondas_db
POSTGRES_USER=ondas_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_EXPIRATION=86400000
JWT_PASSWORD_RESET_EXPIRATION=60000

# ── (Tương lai) Redis ────────────────────────────────────
# REDIS_PASSWORD=

# ── (Tương lai) Email / SMTP ─────────────────────────────
MAIL_USERNAME=john@example.com
MAIL_PASSWORD=CHANGE_ME_email_password
MAIL_FROM=john@example.com

# ── (Tương lai) S3 / Object Storage ─────────────────────
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET_AUDIO=ondas-audio
MINIO_BUCKET_IMAGE=ondas-image